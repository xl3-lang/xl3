{
  "name": "@jinyoung4478/xl3",
  "version": "0.9.0",
  "description": "Use Excel workbooks as templates and render formatted Excel output from Excel data.",
  "keywords": [
    "excel",
    "xlsx",
    "template",
    "transform",
    "spreadsheet",
    "report",
    "automation",
    "xtl"
  ],
  "license": "MIT",
  "homepage": "https://xl3.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jinyoung4478/xl3.git"
  },
  "bugs": {
    "url": "https://github.com/jinyoung4478/xl3/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "xl3-conformance": "dist/bin/conformance.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./conformance-runner": {
      "types": "./dist/conformance-runner.d.ts",
      "import": "./dist/conformance-runner.js"
    },
    "./bundle": "./dist/xl3.bundle.iife.min.js",
    "./bundle/dev": "./dist/xl3.bundle.iife.js"
  },
  "unpkg": "./dist/xl3.bundle.iife.min.js",
  "jsdelivr": "./dist/xl3.bundle.iife.min.js",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.map",
    "README.md",
    "README.ko.md",
    "README.ja.md",
    "README.zh-CN.md",
    "README.zh-TW.md",
    "README.es.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:bundle": "tsup && MINIFY=1 tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "conformance": "node dist/bin/conformance.js --fixture-dir=conformance/fixtures",
    "conformance:stage2": "node dist/bin/conformance.js --fixture-dir=conformance/fixtures --comparison-stage=2",
    "conformance:tz": "TZ=UTC npm run conformance && TZ=America/New_York npm run conformance && TZ=Asia/Seoul npm run conformance",
    "conformance:dashboard": "node conformance/scripts/dashboard.mjs",
    "docs:api": "typedoc",
    "docs:sync": "npm run docs:api && node website/scripts/sync-docs.mjs",
    "docs:dev": "npm run docs:sync && cd website && docusaurus start",
    "docs:build": "npm run docs:sync && cd website && docusaurus build",
    "docs:preview": "cd website && docusaurus serve",
    "examples:build": "node examples/scripts/build.mjs",
    "examples:run": "node examples/scripts/run-all.mjs",
    "bench": "node scripts/bench.mjs",
    "prepublishOnly": "npm run typecheck && npm test && npm run build && npm run build:bundle && npm run conformance && npm run conformance:stage2"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@docusaurus/core": "^3.10.1",
    "@docusaurus/module-type-aliases": "^3.10.1",
    "@docusaurus/preset-classic": "^3.10.1",
    "@docusaurus/tsconfig": "^3.10.1",
    "@docusaurus/types": "^3.10.1",
    "@types/node": "^24.0.0",
    "clsx": "^2.1.1",
    "pptxgenjs": "^4.0.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "sharp": "^0.34.5",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.12"
  }
}
